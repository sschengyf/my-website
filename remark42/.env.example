# Copy to .env and fill in values: cp .env.example .env
# Generate secret: openssl rand -hex 32

REMARK_URL=https://comments.ivancheng.xyz
SECRET=
SITE=ivancheng

# Admin (set ADMIN_SHARED_ID after your first GitHub login)
ADMIN_SHARED_EMAIL=sschengyf@gmail.com
ADMIN_SHARED_ID=

# GitHub OAuth — https://github.com/settings/developers
AUTH_GITHUB_CID=
AUTH_GITHUB_CSEC=

# Optional providers (uncomment when ready)
# AUTH_GOOGLE_CID=
# AUTH_GOOGLE_CSEC=
# AUTH_FACEBOOK_CID=
# AUTH_FACEBOOK_CSEC=

AUTH_ANON=false

# ivancheng.xyz embeds widget from comments.ivancheng.xyz
AUTH_SAME_SITE=none
ALLOWED_HOSTS="'self',https://ivancheng.xyz"
