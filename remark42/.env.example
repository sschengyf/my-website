# Copy to .env and fill in values: cp .env.example .env
# Generate secret: openssl rand -hex 32

REMARK_URL=https://comments.example.com
SECRET=
SITE=your-site-id

# Admin (set ADMIN_SHARED_ID after your first GitHub login)
ADMIN_SHARED_EMAIL=you@example.com
ADMIN_SHARED_ID=

# GitHub OAuth — https://github.com/settings/developers
# Callback: https://comments.example.com/auth/github/callback
AUTH_GITHUB_CID=
AUTH_GITHUB_CSEC=

# Optional providers (uncomment when ready)
# AUTH_GOOGLE_CID=
# AUTH_GOOGLE_CSEC=
# AUTH_FACEBOOK_CID=
# AUTH_FACEBOOK_CSEC=

AUTH_ANON=false

# Required when the blog embeds the widget from a different origin
AUTH_SAME_SITE=none
ALLOWED_HOSTS="'self',https://example.com"
